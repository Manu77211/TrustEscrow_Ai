# For Neon use pooled URL for app/runtime and direct URL for Prisma migrations.
DATABASE_URL="postgresql://<user>:<password>@<neon-pooled-host>/<db>?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://<user>:<password>@<neon-direct-host>/<db>?sslmode=require&connect_timeout=15"
JWT_SECRET="change-this-secret"
PORT=4000
CLIENT_ORIGIN="http://localhost:3000"
