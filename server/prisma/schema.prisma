generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CLIENT
  FREELANCER
}

enum ProjectStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  DISPUTED
}

enum MilestoneStatus {
  PENDING
  SUBMITTED
  APPROVED
}

enum WorkType {
  STRUCTURED
  CREATIVE
}

enum TransactionType {
  DEPOSIT
  LOCKED
  RELEASED
}

enum SubmissionKind {
  DRAFT
  FINAL
}

enum SubmissionStatus {
  SUBMITTED
  VALIDATED
  CHANGES_REQUESTED
  REJECTED
}

enum ValidationDecision {
  APPROVED
  DISPUTED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ContractCategory {
  WEB_BUILD
  API_BACKEND
  DATA_ML
  CREATIVE_ASSET
  MARKETING_CAMPAIGN
}

enum EvidenceType {
  ARTIFACT_LINK
  COMMIT_HASH
  BUILD_LOG
  TEST_REPORT
  SCREENSHOT
  VIDEO
  REQUIREMENT_MAPPING
  METADATA
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          UserRole
  skills        String[]  @default([])
  rating        Float     @default(0)
  trustScore    Float     @default(50)
  experience    String    @default("")
  portfolio     String[]  @default([])
  walletBalance Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  clientProjects Project[] @relation("ClientProjects")
  freelancerProjects Project[] @relation("FreelancerProjects")
  messagesSent  Message[]
  transactions  Transaction[]
  submissions   Submission[]
  projectApplications ProjectApplication[]
}

model Project {
  id                 String        @id @default(cuid())
  title              String
  description        String
  status             ProjectStatus @default(OPEN)
  workType           WorkType      @default(STRUCTURED)
  clientId           String
  freelancerId       String?
  assignedAt         DateTime?
  parsedRequirements Json?
  draftApproved      Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  client             User          @relation("ClientProjects", fields: [clientId], references: [id])
  freelancer         User?         @relation("FreelancerProjects", fields: [freelancerId], references: [id])
  milestones         Milestone[]
  messages           Message[]
  validationCriteria ValidationCriteria[]
  evaluationContract EvaluationContract?
  validationReports  ValidationReport[]
  applications       ProjectApplication[]
}

model Milestone {
  id          String          @id @default(cuid())
  projectId   String
  title       String
  description String
  amount      Float
  status      MilestoneStatus @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submissions Submission[]
  transactions Transaction[]
  validationCriteria ValidationCriteria[]
  validationReports ValidationReport[]
}

model Message {
  id        String   @id @default(cuid())
  projectId String
  senderId  String
  content   String
  fileUrl   String?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  milestoneId String?
  amount      Float
  type        TransactionType
  createdAt   DateTime        @default(now())
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestone   Milestone?      @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
}

model Submission {
  id           String         @id @default(cuid())
  milestoneId  String
  freelancerId String
  fileUrl      String?
  notes        String?
  clientFeedback String?
  kind         SubmissionKind @default(FINAL)
  status       SubmissionStatus @default(SUBMITTED)
  clientRating Float?
  createdAt    DateTime       @default(now())
  milestone    Milestone      @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  freelancer   User           @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  evidences    SubmissionEvidence[]
  evaluationAudits EvaluationRunAudit[]
  validationReport ValidationReport?
}

model ValidationReport {
  id             String             @id @default(cuid())
  submissionId   String             @unique
  projectId      String
  milestoneId    String?
  aiScore        Float              @default(0)
  clientRating   Float              @default(0)
  systemScore    Float              @default(0)
  finalScore     Float              @default(0)
  decision       ValidationDecision
  policyBand     String?
  requiresHumanReview Boolean       @default(false)
  explanation    String?
  breakdown      Json?
  createdAt      DateTime           @default(now())
  submission     Submission         @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  project        Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone      Milestone?         @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
}

model RubricTemplate {
  id              String           @id @default(cuid())
  name            String
  category        ContractCategory
  version         Int              @default(1)
  criteria        Json
  hardFailRules   Json
  weightConfig    Json
  createdAt       DateTime         @default(now())
  contracts       EvaluationContract[]

  @@unique([name, version])
}

model EvaluationContract {
  id                    String           @id @default(cuid())
  projectId             String           @unique
  rubricTemplateId      String?
  category              ContractCategory
  requiredOutputs       Json
  acceptanceCriteria    Json
  scoringRubric         Json
  hardFailConditions    Json
  timeConstraints       Json
  complianceConstraints Json
  version               Int              @default(1)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  project               Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rubricTemplate        RubricTemplate?  @relation(fields: [rubricTemplateId], references: [id], onDelete: SetNull)
  audits                EvaluationRunAudit[]
}

model SubmissionEvidence {
  id           String       @id @default(cuid())
  submissionId String
  evidenceType EvidenceType
  value        String
  metadata     Json?
  createdAt    DateTime     @default(now())
  submission   Submission   @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model EvaluationRunAudit {
  id                 String              @id @default(cuid())
  submissionId       String
  contractId         String?
  deterministicScore Float
  aiScoreA           Float
  aiScoreB           Float
  consistencyScore   Float
  fusionScore        Float
  policyBand         String
  requiresHumanReview Boolean           @default(false)
  decisionTrace      Json
  createdAt          DateTime            @default(now())
  submission         Submission          @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  contract           EvaluationContract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
}

model ValidationCriteria {
  id         String   @id @default(cuid())
  projectId  String
  milestoneId String?
  type       WorkType
  rules      Json
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone  Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
}

model ProjectApplication {
  id           String            @id @default(cuid())
  projectId    String
  freelancerId String
  message      String?
  proposedAmount Float?
  estimatedDays Int?
  deliverables  String?
  status       ApplicationStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  freelancer   User              @relation(fields: [freelancerId], references: [id], onDelete: Cascade)

  @@unique([projectId, freelancerId])
}
